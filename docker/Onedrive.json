{
  "name": "Onedrive",
  "repo": "driveone/onedrive:latest",
  "network": "bridge",
  "custom_ip": "",
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "-it",
  "post_parameters": "",
  "web_ui_url": "",
  "icon": "https://github.com/erebus04/mos-hub-templates/blob/fca86b19798b0e7149964d50409325bd360c6a28/images/onedrive.png",
  "paths": [
    {
      "name": "Configuration",
      "mode": "rw",
      "host": "/mnt/cache/appdata/yourapp",
      "container": "/onedrive/conf/"
    },
    {
      "name": "Data",
      "mode": "rw",
      "host": "/mnt/cache/appdata/yourapp",
      "container": "/onedrive/data/"
    }
  ],
  "ports": [],
  "variables": [
    {
      "name": "UID",
      "key": "ONEDRIVE_UID",
      "value": "500",
      "mask": false
    },
    {
      "name": "GID",
      "key": "ONEDRIVE_GID",
      "value": "500",
      "mask": false
    }
  ],
  "devices": [],
  "labels": [],
  "gpus": []
}
