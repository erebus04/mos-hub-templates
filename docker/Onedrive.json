{
  "name": "Onedrive",
  "repo": "driveone/onedrive:latest",
  "network": "bridge",
  "custom_ip": "",
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "-it",
  "post_parameters": "",
  "web_ui_url": "",
  "project": "https://github.com/abraunegg/onedrive/blob/master/docs/Docker.md",
  "description": "A free Microsoft OneDrive Client which supports OneDrive Personal, OneDrive for Business, OneDrive for Office365 and SharePoint.",
  "icon": "https://raw.githubusercontent.com/erebus04/mos-hub-templates/blob/main/images/onedrive.png",
  "paths": [
    {
      "name": "Configuration",
      "mode": "rw",
      "host": "/mnt/cache/appdata/yourapp",
      "container": "/onedrive/conf/"
    },
    {
      "name": "Data",
      "mode": "rw",
      "host": "/mnt/cache/appdata/yourapp",
      "container": "/onedrive/data/"
    }
  ],
  "ports": [],
  "variables": [
    {
      "name": "UID",
      "key": "ONEDRIVE_UID",
      "value": "500",
      "mask": false
    },
    {
      "name": "GID",
      "key": "ONEDRIVE_GID",
      "value": "500",
      "mask": false
    }
  ],
  "devices": [],
  "labels": [],
  "gpus": []
}
